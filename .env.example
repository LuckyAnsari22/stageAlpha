# ==========================================
# StageAlpha Environment Configuration
# ==========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Generate JWT secrets with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ==========================================

# Database
# PostgreSQL connection string to the local database
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/stagealpha

# JWT
# Secret key used to sign access tokens (short-lived)
# MUST be a unique random hex string (64 bytes recommended)
JWT_SECRET=REPLACE_WITH_RANDOM_HEX_64_BYTES
# Secret key used to sign refresh tokens (long-lived)
# MUST be different from JWT_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_RANDOM_HEX_64_BYTES
# Expiration time for access tokens
JWT_ACCESS_EXPIRY=15m
# Expiration time for refresh tokens
JWT_REFRESH_EXPIRY=7d

# Redis (optional — app works without it)
# Redis connection string for caching and sessions
# Comment out or leave empty if Redis is not installed
REDIS_URL=redis://localhost:6379

# App
# Port the server runs on
PORT=3000
# Environment stage (development or production)
NODE_ENV=development
# Allowed origin for CORS (e.g. frontend URL)
CORS_ORIGIN=http://localhost:3000

# Security
# Work factor for bcrypt hashing algorithm (12 recommended for production)
BCRYPT_ROUNDS=12
